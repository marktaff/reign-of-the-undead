# Ignore SVN metadata directories
.svn/

# Ignore build/output directories (adjust as needed)
# build/
dist/
bin/
obj/
# Ignore everything inside build
/trunk/build/*
# But do not ignore the build directory itself
!/trunk/build/

# Track the directory itself
!/trunk/local/
# Ignore all files inside trunk/local
/trunk/local/*
# But do not ignore readme.md
!/trunk/local/readme.md

# Ignore editor/IDE files
.vscode/
.idea/
*.suo
*.user
*.log
*.code-workspace
.env
_private*

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore temporary files
*.tmp
*.bak
*.swp